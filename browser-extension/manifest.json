{
  "manifest_version": 3,
  "name": "InterviewPrep AI Job Saver",
  "version": "0.1.0",
  "description": "Save the current job page to InterviewPrep AI for interview preparation.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_title": "Save job to InterviewPrep AI",
    "default_popup": "popup.html"
  }
}
