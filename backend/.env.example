APP_ENV=development
DATABASE_URL=sqlite:///./interviewprep.db
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AUTH_SECRET_KEY=change_this_to_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REQUIRE_AUTH=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TAVILY_API_KEY=
REGISTRATION_OTP_REQUIRED=true
EMAIL_PROVIDER=resend
EMAIL_FROM="InterviewPrep AI <onboarding@resend.dev>"
EMAIL_OTP_DEV_MODE=true
EMAIL_OTP_EXPIRE_MINUTES=10
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_HOURLY_LIMIT=5
RESEND_API_KEY=

# Production example:
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/interviewprep
# FRONTEND_ORIGINS=https://your-frontend-domain.vercel.app
